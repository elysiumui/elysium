#!/bin/bash
# Launcher script for the Snapshot Relay .app bundle.
# macOS binds Screen-Recording permission to the bundle that invokes
# screencapture, so running the Python script *via* this app gives us a
# stable target for the permission grant.
set -e
HERE="$(cd "$(dirname "$0")" && pwd -P)"
REPO_ROOT="$(cd "$HERE/../../../.." && pwd -P)"
VENV_PY="$REPO_ROOT/.venv/bin/python"
SCRIPT="$REPO_ROOT/examples/snapshot-relay/__main__.py"
if [ ! -x "$VENV_PY" ]; then
  echo "snapshot-relay: .venv/bin/python not found at $VENV_PY" >&2
  echo "Run 'maturin develop' in the repo root first." >&2
  exit 1
fi
exec "$VENV_PY" "$SCRIPT"
